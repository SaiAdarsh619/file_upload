<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CloudVault – Secure File Storage for Everyone</title>
    <meta name="description"
        content="CloudVault lets you securely upload, organize, and access your files and folders from anywhere. Sign up free today.">
    <link rel="stylesheet" href="/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>

<body class="landing-body">

    <!-- Nav -->
    <nav class="landing-nav">
        <div class="landing-nav-inner">
            <div class="landing-logo">
                <span class="landing-logo-icon">☁️</span>
                <span class="landing-logo-name">CloudVault</span>
            </div>
            <div class="landing-nav-actions">
                <a href="/login" class="nav-link">Sign In</a>
                <a href="/register" class="nav-btn-primary">Get Started Free</a>
            </div>
        </div>
    </nav>

    <!-- Hero -->
    <section class="landing-hero">
        <div class="landing-hero-inner">
            <div class="hero-badge">✨ Simple &amp; Secure Cloud Storage</div>
            <h1 class="hero-title">Your files,<br><span class="hero-title-accent">anywhere you go</span></h1>
            <p class="hero-sub">Upload files and folders in seconds. Access them from any device, any time. Your data is
                isolated to your account — no one else can see it.</p>
            <div class="hero-ctas">
                <a href="/register" class="cta-btn-primary">Create a free account</a>
                <a href="/login" class="cta-btn-secondary">Sign in</a>
            </div>
            <p class="hero-note">No credit card required · Free forever for personal use</p>
        </div>
        <!-- Decorative blob -->
        <div class="hero-blob"></div>
        <div class="hero-blob hero-blob-2"></div>
    </section>

    <!-- Features -->
    <section class="landing-features">
        <div class="landing-section-inner">
            <h2 class="section-title">Everything you need to stay organized</h2>
            <p class="section-sub">A clean, fast file manager that gets out of your way.</p>
            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-icon">🔒</div>
                    <h3 class="feature-title">Per-user isolation</h3>
                    <p class="feature-desc">Every account has its own private space. Your files are never mixed with
                        other users' data.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">📂</div>
                    <h3 class="feature-title">Folder support</h3>
                    <p class="feature-desc">Upload entire folder trees in one go. Browse, navigate, and organize just
                        like your desktop.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">⚡</div>
                    <h3 class="feature-title">Drag &amp; drop uploads</h3>
                    <p class="feature-desc">Drop files directly onto the page. Stage multiple items, review them, then
                        upload with one click.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">🔍</div>
                    <h3 class="feature-title">Instant search</h3>
                    <p class="feature-desc">Find any file instantly with live search. No page reloads — results update
                        as you type.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">📦</div>
                    <h3 class="feature-title">Batch download</h3>
                    <p class="feature-desc">Select multiple files and download them in a single ZIP archive, right from
                        your browser.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">🗂️</div>
                    <h3 class="feature-title">Grid &amp; list views</h3>
                    <p class="feature-desc">Switch between a visual grid and a detailed list view. Sort by name, date,
                        or size.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Banner -->
    <section class="landing-cta-banner">
        <div class="landing-section-inner cta-banner-inner">
            <h2 class="cta-banner-title">Ready to get started?</h2>
            <p class="cta-banner-sub">Create your account in under 30 seconds.</p>
            <a href="/register" class="cta-btn-primary cta-banner-btn">Sign up — it's free</a>
        </div>
    </section>

    <!-- Footer -->
    <footer class="landing-footer">
        <div class="landing-section-inner footer-inner">
            <div class="footer-logo">
                <span>☁️</span> CloudVault
            </div>
            <div class="footer-links">
                <a href="/login">Sign In</a>
                <a href="/register">Register</a>
            </div>
        </div>
    </footer>

</body>

</html>